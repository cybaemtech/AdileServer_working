<?xml version="1.0" encoding="UTF-8"?>
<configuration>
  <system.webServer>
    <!-- Inherit PHP configuration from parent -->
    <httpErrors existingResponse="PassThrough" />
    
    <!-- IMPORTANT: Clear CORS headers inherited from parent dist/web.config -->
    <!-- PHP cors.php handles all CORS headers for API responses -->
    <httpProtocol>
      <customHeaders>
        <clear />
      </customHeaders>
    </httpProtocol>
  </system.webServer>
</configuration>

